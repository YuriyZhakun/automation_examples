            {
              "id": "0bca3f49-f613-4eaf-b820-9f349303fc6a",
              "name": "email_body",
              "value": "={{ \n(() => {\n  const summary = $('Average Analytics SQL').item.json;\n  const topListings = $('Top 3 Listings SQL').all().map(i => i.json);\n  const office_id = $('Switch').item.json.output.office_id;\n\n  return `\n    <div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333; line-height: 1.6;\">\n      <p>Hello,</p>\n      <p>Thank you for your request. Here's the performance summary for the office <strong>${office_id}</strong>:</p>\n      <h3>📊 <u>Overall Performance</u></h3>\n      <ul style=\"margin-left: 20px;\">\n        <li><strong>Total listings:</strong> ${summary.total_listings}</li>\n        <li><strong>Total page views:</strong> ${summary.total_pageviews}</li>\n        <li><strong>Total leads:</strong> ${summary.total_leads}</li>\n        <li><strong>Conversion rate:</strong> ${summary.conversion_rate}%</li>\n        <li><strong>Average leads (per Listing):</strong> ${summary.avg_lead_value}</li>\n      </ul>\n      <h3>🔥 <u>Top Performing Listings</u></h3>\n      ${topListings.map((listing, index) => `\n        <p style=\"margin-left: 20px;\"><strong>#${index + 1} - Listing ID:</strong> ${listing.listing_id}</p>\n        <ul style=\"margin-left: 40px;\">\n          <li><strong>Page views:</strong> ${listing.total_pageviews}</li>\n          <li><strong>Leads:</strong> ${listing.total_leads}</li>\n          <li><strong>Conversion rate:</strong> ${listing.conversion_rate}%</li>\n        </ul>\n      `).join('')}\n      <p>If you need further assistance or exports, feel free to reach out.</p>\n      <p>Best regards,<br>Your Support Team</p>\n    </div>\n  `;\n})() \n}}\n",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2512, 112],
      "id": "12310512-8efd-42e9-9d19-6c064d8f6c49",
