              "id": "0bca3f49-f613-4eaf-b820-9f349303fc6a",
              "name": "email_body",
              "value": "={{\n(() => {\n  const { countryName, city, locality } = $('Location API').item.json;\n  const { currency, country_code } = $('Listing SQL').item.json;\n  const price = $json.finalPrice.toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n  const targetCurrency = $('Information Extractor').item.json.output?.target_currency || currency || 'USD';\n  const finalCountry = `${countryName || \"Unknown Country\"} (${country_code})`;\n  const finalCity = city || `Unknown city (${locality})`;\n  const finalCurrency = targetCurrency;\n\n  return `\n    <p>Hello,</p>\n    <p>Thank you for your request. Below is the information we could retrieve regarding the requested listing:</p>\n    <h3>📍 Location Details</h3>\n    <ul style=\"margin-left: 20px;\">\n      <li><strong>Country:</strong> ${finalCountry}</li>\n      <li><strong>City:</strong> ${finalCity}</li>\n      <li><strong>Price:</strong> ${price} ${finalCurrency}</li>\n    </ul>\n    <p>If you need more details or support with similar listings, feel free to contact us.</p>\n    <p>Best regards,<br>Your Support Team</p>\n  `;\n})()\n}}",
              "type": "string"
            }
          ]
        },
        "options": {}
