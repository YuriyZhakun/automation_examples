    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  COUNT(DISTINCT l.listing_id) AS total_listings,\n  SUM(CAST(e.pageviews AS INTEGER)) AS total_pageviews,\n  SUM(e.leads) AS total_leads,\n  CASE \n    WHEN SUM(CAST(e.pageviews AS INTEGER)) > 0 \n    THEN ROUND(SUM(e.leads)::DECIMAL / SUM(CAST(e.pageviews AS INTEGER)) * 100, 2) \n    ELSE 0 \n  END AS conversion_rate,\n  ROUND(AVG(e.leads)::DECIMAL, 2) AS avg_lead_value\nFROM engagement e \nJOIN listings l ON e.listing_id = l.listing_id\nWHERE l.office_id = {{ $('Information Extractor').item.json.output.office_id }}::TEXT;",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [1840, 128],
      "id": "7ca80005-6ab7-4480-8124-e882b0382733",
      "name": "Average Analytics SQL",
      "alwaysOutputData": true,
      "credentials": {
        "postgres": {
          "id": "OvJZ6ZAtoKkHzZ81",
          "name": "Postgres account 2"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  agg.listing_id,\n  agg.total_pageviews,\n  agg.total_leads,\n  CASE \n    WHEN agg.total_pageviews > 0 \n    THEN ROUND(agg.total_leads::DECIMAL / agg.total_pageviews * 100, 2)\n    ELSE 0\n  END AS conversion_rate\n  \nFROM (\n  SELECT \n    e.listing_id,\n    SUM(CAST(e.pageviews AS INTEGER)) AS total_pageviews,\n    SUM(e.leads) AS total_leads\n  FROM engagement e\n  JOIN listings l ON e.listing_id = l.listing_id\n  WHERE l.office_id = {{ $('Information Extractor').item.json.output.office_id }}::TEXT\n  GROUP BY e.listing_id\n) AS agg\nORDER BY agg.total_pageviews DESC\nLIMIT 3;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [2304, 112],
      "id": "8e96e281-a2c3-4d9e-a6f7-f825666adb49",
