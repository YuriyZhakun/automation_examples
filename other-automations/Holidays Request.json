    {
      "parameters": {
        "jsCode": "const afterDate = new Date($('Webhook').first().json.query.after_date);\n\nconst filteredHolidays = $input.first().json\n  .filter((holiday) => new Date(holiday.date) >= afterDate)\n  .map((holiday) => ({\n    date: holiday.date,\n    holiday_name: holiday.localName\n  }));\n\nreturn { filteredHolidays };\n"
