    {
      "parameters": {
        "jsCode": "const items = $input.all().map(item => item.json);\nconst errors = [];\n\nfor (const { query } of items) {\n  const { country_name, after_date, formatter } = query || {};\n\n  if (!country_name || !after_date) {\n    errors.push({ json: { error: \"Missing required parameter. Please provide country_name and after_date.\" } });\n  } else if (!/^\\d{4}-\\d{2}-\\d{2}$/.test(after_date)) {\n    errors.push({ json: { error: \"Invalid after_date format. Please use YYYY-MM-DD.\" } });\n  } \n  \n  else if (formatter && ![\"alternating_case_formatter\", \"uppercase_formatter\", \"lowercase_formatter\"].includes(formatter)) {\n    errors.push({ json: { error: \"Invalid formatter value. Supported values: alternating_case_formatter, uppercase_formatter, lowercase_formatter.\" } });\n}\n\n  \n}\n\nreturn errors.length > 0 ? errors : [{ json: { error: null } }];\n"
      },
