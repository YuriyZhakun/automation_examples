    {
      "parameters": {
        "jsCode": "const countryName = $(\"Webhook\").first().json.query.country_name.toLowerCase();\nconst countryList = $input.first().json;\n\nlet countryCode = null;\nfor (const item of countryList) {\n  if ((item.name.toLowerCase()) === countryName) {\n    countryCode = item.countryCode;\n    break;\n  }\n}\nif (!countryCode) {\n  return [{ json: { error: \"Invalid country_name. Please provide a valid country name.\" } }];\n}\nreturn [{ json: { code: countryCode } }];\n"
      },
